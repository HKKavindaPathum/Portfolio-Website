datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Admin {
  id       Int    @id @default(autoincrement())
  username String @unique
  password String
}

model Project {
  id          Int     @id @default(autoincrement())
  title       String
  description String  @db.Text
  techStack   String
  githubLink  String?
  liveLink    String?
  imageUrl    String?
  imageFile   String? @db.LongText
}

model CvDetails {
  id                Int     @id @default(autoincrement())
  fullName          String
  professionalTitle String
  aboutSummary      String  @db.Text
  cvUrl             String
  githubUrl         String?
  linkedinUrl       String?
  email             String?
  phone             String?
  location          String?
  statsExperience   String? @default("5+")
  statsProjects     String? @default("30+")
  statsTechnologies String? @default("15+")
  heroDescription   String? @db.Text
  cvFile            String? @db.LongText
}

model Education {
  id          Int    @id @default(autoincrement())
  degree      String
  institution String
  period      String
  description String @db.Text
}

model Skill {
  id       Int    @id @default(autoincrement())
  name     String
  category String
}
